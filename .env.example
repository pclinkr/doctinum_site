# Frontend calls Next.js proxy route by default:
# NEXT_PUBLIC_RETELL_PROXY_PATH="/api/retell/test-web-call"
NEXT_PUBLIC_RETELL_PROXY_PATH="/api/retell/test-web-call"

# REQUIRED: Retell API Key (server-side only, NEVER expose in NEXT_PUBLIC_*)
# Get your API key from: https://dashboard.retellai.com/
# This is used by /api/retell/test-web-call to create web calls
RETELL_API_KEY="your_retell_api_key_here"

# Retell agent used for the medical voice demo.
NEXT_PUBLIC_RETELL_AGENT_ID="agent_9f250d09bcb3b222b1baa1ff88"

# Optional: avatar image shown inside the phone.
# Local example: "/assets/voice-demo/avatar-default.jpg"
# Remote example (S3/Supabase): "https://cdn.example.com/voice/avatar.jpg"
NEXT_PUBLIC_VOICE_DEMO_AVATAR_URL="/assets/voice-demo/avatar-default.jpg"

# Optional: fallback audio file URL used if live call setup fails.
# Local example: "/assets/voice-demo/fallback-medical-call.mp3"
# Remote example (S3/Supabase): "https://cdn.example.com/voice/fallback-call.mp3"
NEXT_PUBLIC_VOICE_DEMO_FALLBACK_AUDIO_URL="/assets/voice-demo/fallback-medical-call.mp3"

# Optional PUBLIC token for a protected backend endpoint.
# Use short-lived tokens only. Do NOT place your Retell API key here.
RETELL_DEMO_API_KEY=""

# REQUIRED: Upstash Redis credentials for rate limiting and budget tracking
# Get these from: https://console.upstash.com/
# 1. Create a free Redis database
# 2. Copy the REST URL and REST Token from the database details
UPSTASH_REDIS_REST_URL="https://your-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token_here"

# Security rule:
# NEVER expose RETELL_API_KEY in NEXT_PUBLIC_* variables.
# RETELL_API_KEY must stay server-side only.

ORTHO_RETELL_AGENT_ID=""
ORTHO_RETELL_AGENT_VERSION=1
AESTHETIC_RETELL_AGENT_ID=""
AESTHETIC_RETELL_AGENT_VERSION=1
ONCOLOGY_RETELL_AGENT_ID=""
ONCOLOGY_RETELL_AGENT_VERSION=1
CARDIOLOGY_RETELL_AGENT_ID=""
CARDIOLOGY_RETELL_AGENT_VERSION=1
